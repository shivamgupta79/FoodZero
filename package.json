{
  "name": "foodzero-platform",
  "version": "1.0.0",
  "description": "FoodZero - Zero food waste platform",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/server.js",
    "client": "cd client && npm run dev",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.14"
  }
}
